{
  "manifest_version": 3,
  "name": "Bible Verse",
  "description": "Get daily Bible verses with English and Bengali translations. Save favorites, track your reading streak, and share verses with friends.",
  "version": "0.0.01",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Daily Bible Verse"
  },
  "permissions": [
    "storage"
  ]
}
