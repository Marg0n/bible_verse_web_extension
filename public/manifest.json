{
  "manifest_version": 3,
  "name": "Bible Verse",
  "description": "Get daily Bible verses in English and Bengali. Save favorites, track reading streaks, and share verses.",
  "version": "0.0.1",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Bible Verse"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.example.com/*"
  ]
}
